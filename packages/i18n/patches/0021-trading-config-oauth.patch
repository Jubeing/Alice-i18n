+/**
+ * Sync Longbridge credentials to MCP config.json and restart MCP.
+ * Called after a Longbridge account is saved/updated.
+ */
+async function syncLongbridgeMcpConfig(account: AccountConfig): Promise<void> {
+  if (account.type !== 'longbridge') return
+  const configPath = resolve(process.cwd(), 'packages/longport/config.json')
+  const lbConfig = {
+    appKey: (account.brokerConfig as Record<string, unknown>).appKey as string ?? '',
+    appSecret: (account.brokerConfig as Record<string, unknown>).appSecret as string ?? '',
+    accessToken: (account.brokerConfig as Record<string, unknown>).accessToken as string ?? '',
+    paper: (account.brokerConfig as Record<string, unknown>).paper === true,
+    port: 3004,
+  }
+  try {
+    writeFileSync(configPath, JSON.stringify(lbConfig, null, 2))
+    execSync('sudo systemctl restart openalice', { stdio: 'ignore' })
+  } catch (e) {
+    console.warn('[Longbridge MCP] Failed to sync config:', e)
+  }
+}
